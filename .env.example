# Copy this file to .env.local for local development
# On Vercel, set these in Project Settings → Environment Variables

# Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Optional: model selection (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# TMDB API key for content-based theme generation (get from https://www.themoviedb.org/settings/api)
# Optional: if not set, content-based themes fall back to text-only generation
TMDB_API_KEY=your_tmdb_key_here